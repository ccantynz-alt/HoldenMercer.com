# Deepgram API key — get one free at https://console.deepgram.com
# Used client-side by both SovereignVoice (Voice Engine tab) and
# DictationVoice (Dictation Studio tab). Streams audio to nova-2 over WSS.
# Acceptable for a personal/local tool; do NOT commit a real key.
VITE_DEEPGRAM_API_KEY=

# Optional: set if SOVEREIGN_API_KEY is configured in the backend .env
VITE_SOVEREIGN_API_KEY=
