# Shared key the SPA sends as X-Sovereign-Key on every backend call.
# Must match SOVEREIGN_SECRET_KEY in the backend env.
# Generate: python -c "import secrets; print(secrets.token_urlsafe(32))"
#
# This value is baked into the JS bundle at build time, so it's not a real
# secret — it's a shared token that prevents drive-by traffic from burning
# your Anthropic credit. Don't reuse it for anything that needs to be
# actually secret.
VITE_SOVEREIGN_API_KEY=
