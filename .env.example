# ── Core Engines ──────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
DEEPGRAM_API_KEY=your_nova_2_key
OPENAI_API_KEY=sk-...                    # Whisper transcription + embeddings

# ── Database (Fortress) ───────────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-service-role-key       # service_role key for server-side writes
DATABASE_URL=postgresql://user:pass@host:5432/sovereign

# ── AWS Bedrock failover ──────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
BEDROCK_MODEL_ID=anthropic.claude-sonnet-4-5

# ── Redis (Celery) ────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── App ───────────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
ENVIRONMENT=production
DEVELOPMENT_MODE=false

# ── Security ──────────────────────────────────────────────────────────────────
# Generate: python -c "import secrets; print(secrets.token_urlsafe(32))"
SOVEREIGN_SECRET_KEY=
ALLOWED_ORIGINS=https://holdenmercer.com

# ── Infrastructure mode ────────────────────────────────────────────────────────
# "DEEPGRAM" = use Deepgram cloud  |  "CRONTECH" = use CronTech native voice
# Auto-promotes to CRONTECH when CRONTECH_API_KEY is set and CRONTECH_ENABLED=true
INFRA_MODE=DEEPGRAM
DEEPGRAM_API_KEY=your_nova_2_key

# ── GlueCron (GitHub as native memory) ────────────────────────────────────────
# Read PAT: repo:read scope  |  Write: repo:write scope (same token can do both)
GLUECRON_GITHUB_TOKEN=github_pat_...
GLUECRON_GITHUB_ORG=your-github-username-or-org
GLUECRON_STAGING=true       # write to 'staging' branch, not main

# ── CronTech ──────────────────────────────────────────────────────────────────
CRONTECH_ENABLED=false
CRONTECH_API_URL=https://api.crontech.ai
CRONTECH_API_KEY=
CRONTECH_VOICE_URL=         # WSS base URL for CronTech voice (if different from API URL)
